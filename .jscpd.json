{
  "mode": "mild",
  "threshold": 0,
  "reporters": ["console"],
  "minTokens": 60,
  "minLines": 5,
  "format": ["typescript"],
  "pattern": "src/**/*.ts",
  "ignore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/out/**",
    "**/*.test.ts",
    "**/*.test-suite.ts",
    "**/*.integration-test.ts"
  ],
  "gitignore": true,
  "absolute": false,
  "silent": false
}
