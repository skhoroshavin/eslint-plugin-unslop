{
  "name": "eslint-plugin-unslop",
  "version": "0.1.5",
  "description": "ESLint plugin with rules for reducing AI-generated code smells",
  "repository": {
    "type": "git",
    "url": "https://github.com/skhoroshavin/eslint-plugin-unslop"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "fix": "knip --fix && eslint . --fix && prettier . --write",
    "verify": "prettier . --check && knip && depcruise src && jscpd && tsc --noEmit && tsup && eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "ai",
    "code-quality",
    "unslop"
  ],
  "license": "MIT",
  "peerDependencies": {
    "eslint": ">=9.0.0",
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/estree": "^1.0.8",
    "@types/node": "^22.18.0",
    "@typescript-eslint/parser": "^8.57.2",
    "dependency-cruiser": "^17.3.10",
    "eslint": "^9.39.1",
    "globals": "^17.4.0",
    "jscpd": "^4.0.8",
    "knip": "^6.1.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^3.2.4"
  }
}
